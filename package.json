{
  "name": "market-diary-terminal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "node scripts/sync-reviews.mjs",
    "dev": "nuxt dev",
    "prebuild": "node scripts/sync-reviews.mjs",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "auth:hash": "node scripts/hash-admin-password.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "trading:import": "node scripts/import-trading-workbook.mjs",
    "typecheck": "nuxt typecheck",
    "test:unit": "node scripts/sync-reviews.mjs && node --test tests/sync-reviews.test.mjs && vitest run",
    "test": "pnpm run test:unit",
    "lint": "eslint .",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "md-editor-v3": "^6.5.4",
    "nuxt": "^4.0.0",
    "nuxt-auth-utils": "^0.5.29",
    "sanitize-html": "^2.17.0",
    "vue": "^3.5.0",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@nuxt/test-utils": "^3.19.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "22.19.19",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-vue": "6.0.8",
    "@vue/test-utils": "^2.4.6",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "happy-dom": "^20.0.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.0.0"
  },
  "type": "module"
}
