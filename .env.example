# At least 32 characters. Used to encrypt the administrator session cookie.
NUXT_SESSION_PASSWORD=

# Generate with: pnpm run auth:hash
NUXT_ADMIN_PASSWORD_HASH=

# Fine-grained GitHub token, restricted to this repository with Contents read/write.
NUXT_GITHUB_TOKEN=

NUXT_GITHUB_OWNER=SmartDengC
NUXT_GITHUB_REPO=stock-exchange-reviews
NUXT_GITHUB_BRANCH=main
